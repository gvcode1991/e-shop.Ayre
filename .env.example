# AyRe environment example
# Copiar este archivo como .env para trabajar local.
# En Render cargar las mismas variables en Environment.
# No subir nunca el archivo .env real a GitHub.

# Server
PORT=3001
HOST=0.0.0.0

# Frontend / API
# Local:
CLIENT_ORIGIN=http://127.0.0.1:5173
VITE_API_URL=http://127.0.0.1:3001/api
PUBLIC_APP_URL=http://127.0.0.1:3001

# Render:
# CLIENT_ORIGIN=https://e-shop-ayre.onrender.com
# VITE_API_URL=/api
# PUBLIC_APP_URL=https://e-shop-ayre.onrender.com

# WhatsApp en formato internacional, sin + ni espacios.
VITE_WHATSAPP_NUMBER=5491133441047

# MongoDB Atlas
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@TU_CLUSTER.mongodb.net/ayre-shop?retryWrites=true&w=majority
MONGODB_DB_NAME=ayre-shop

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=tu_api_key
CLOUDINARY_API_SECRET=tu_api_secret
CLOUDINARY_FOLDER=ayre-products

# Email SMTP con Gmail
# Requiere verificacion en 2 pasos y App Password de Google.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=tu_gmail@gmail.com
SMTP_PASS=tu_app_password_de_16_caracteres
MAIL_FROM=AyRe <tu_gmail@gmail.com>
